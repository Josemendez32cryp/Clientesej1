@page "/vehiculos-ingreso"

@using Clientesej1.Models
@using Clientesej1.Service
@inject VehiculosService VehiculosService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<EditForm Model="@NuevoVehiculo" OnValidSubmit="@HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger" />

    <h3>Registrar Nuevo Vehículo</h3>

    <div class="container text-center">
        <div class="row">
            <div class="col">
                <div class="form-group mb-3">
                    <label>Placa:</label>
                    <InputText class="form-control" @bind-Value="NuevoVehiculo.Placa" />
                    <ValidationMessage For="@(() => NuevoVehiculo.Placa)" />
                </div>
            </div>

            <div class="col">
                <div class="form-group mb-3">
                    <label>Marca:</label>
                    <InputText class="form-control" @bind-Value="NuevoVehiculo.Marca" />
                    <ValidationMessage For="@(() => NuevoVehiculo.Marca)" />
                </div>
            </div>

            <div class="col">
                <div class="form-group mb-3">
                    <label>Modelo:</label>
                    <InputText class="form-control" @bind-Value="NuevoVehiculo.Modelo" />
                    <ValidationMessage For="@(() => NuevoVehiculo.Modelo)" />
                </div>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary" disabled="@isProcessing">
        @if (isProcessing)
        {
            <span class="spinner-border spinner-border-sm me-1"></span>
            <span>Guardando...</span>
        }
        else
        {
            <span>Guardar Vehículo</span>
        }
    </button>

    <a href="/vehiculos-listar" class="btn btn-secondary ms-2">Ver Listado</a>
</EditForm>

@if (!string.IsNullOrEmpty(mensajeExito))
{
    <div class="alert alert-success mt-3">@mensajeExito</div>
}

@if (!string.IsNullOrEmpty(mensajeError))
{
    <div class="alert alert-danger mt-3">@mensajeError</div>
}

@code {
    private Vehiculo NuevoVehiculo = new Vehiculo();
    private bool isProcessing = false;
    private string mensajeExito = string.Empty;
    private string mensajeError = string.Empty;

    private async Task HandleValidSubmit()
    {
        isProcessing = true;
        mensajeExito = string.Empty;
        mensajeError = string.Empty;

        try
        {
            var lista = VehiculosService.Leer();

            if (lista.Any(v => v.Placa == NuevoVehiculo.Placa))
            {
                mensajeError = $"Ya existe un vehículo con la placa {NuevoVehiculo.Placa}";
                return;
            }

            VehiculosService.Guardar(NuevoVehiculo);
            mensajeExito = $"Vehículo {NuevoVehiculo.Marca} registrado";

            NuevoVehiculo = new Vehiculo();

            await Task.Delay(2000);
            Navigation.NavigateTo("/vehiculos-listar");
        }
        catch (Exception ex)
        {
            mensajeError = ex.Message;
        }
        finally
        {
            isProcessing = false;
        }
    }
}